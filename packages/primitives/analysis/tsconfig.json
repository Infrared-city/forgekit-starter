{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "types": [],
    // Inherit baseUrl from root (monorepo root). DO NOT override baseUrl here --
    // a local baseUrl of "." would cause the `react/` sub-directory to shadow
    // the real `react` npm package when TypeScript resolves bare specifiers.
    //
    // paths values are relative to the inherited baseUrl (monorepo root).
    "paths": {
      "@forge-kit/plugin-contracts": ["./packages/interfaces/shared/index.ts"],
      "@forge-kit/plugin-contracts/*": ["./packages/interfaces/shared/*"],
      "@forge-kit/buildings": ["./packages/primitives/buildings/index.ts"],
      "@forge-kit/buildings/*": ["./packages/primitives/buildings/*"],
      "@forge-kit/analysis": ["./packages/primitives/analysis/index.ts"],
      "@forge-kit/analysis/*": ["./packages/primitives/analysis/*"]
    }
  },
  // include/exclude are relative to this tsconfig file's location.
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["__tests__"]
}
