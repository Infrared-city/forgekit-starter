{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,

    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "baseUrl": ".",
    "paths": {
      "ui": ["./packages/ui/src/index.ts"],
      "client": ["apps/base/client/src"],
      "@infrared/design-tokens": ["./packages/design-tokens/src/index.ts"],
      "@infrared/design-tokens/*": ["./packages/design-tokens/src/*"],
      "@infrared/three-theme": ["./packages/three-theme/src/index.ts"],
      "@infrared/three-theme/*": ["./packages/three-theme/src/*"],
      "@infrared/analysis-colors": ["./packages/analysis-colors/src/index.ts"],
      "@infrared/analysis-colors/*": ["./packages/analysis-colors/src/*"],
      "@infrared/mapbox-theme": ["./packages/mapbox-theme/src/index.ts"],
      "@infrared/mapbox-theme/*": ["./packages/mapbox-theme/src/*"],
      "@forge-kit/plugin-contracts": ["./packages/interfaces/shared/index.ts"],
      "@forge-kit/plugin-contracts/*": ["./packages/interfaces/shared/*"],
      "@forge-kit/geo-core": ["./packages/primitives/geo-core/index.ts"],
      "@forge-kit/geo-core/*": ["./packages/primitives/geo-core/*"],
      "@forge-kit/buildings": ["./packages/primitives/buildings/index.ts"],
      "@forge-kit/buildings/core": ["./packages/primitives/buildings/core/index.ts"],
      "@forge-kit/buildings/react": ["./packages/primitives/buildings/react/index.ts"],
      "@forge-kit/buildings/*": ["./packages/primitives/buildings/*"],
      "@forge-kit/analysis": ["./packages/primitives/analysis/index.ts"],
      "@forge-kit/analysis/core": ["./packages/primitives/analysis/core/index.ts"],
      "@forge-kit/analysis/react": ["./packages/primitives/analysis/react/index.ts"],
      "@forge-kit/analysis/*": ["./packages/primitives/analysis/*"],
      "@forge-kit/ground-materials": ["./packages/primitives/ground-materials/index.ts"],
      "@forge-kit/ground-materials/core": [
        "./packages/primitives/ground-materials/core/index.ts"
      ],
      "@forge-kit/ground-materials/react": [
        "./packages/primitives/ground-materials/react/index.ts"
      ],
      "@forge-kit/ground-materials/*": ["./packages/primitives/ground-materials/*"],
      "@forge-kit/indoor-analysis": ["./packages/primitives/indoor-analysis/index.ts"],
      "@forge-kit/indoor-analysis/core": ["./packages/primitives/indoor-analysis/core/index.ts"],
      "@forge-kit/indoor-analysis/react": [
        "./packages/primitives/indoor-analysis/react/index.ts"
      ],
      "@forge-kit/indoor-analysis/*": ["./packages/primitives/indoor-analysis/*"],
      "@forge-kit/vegetation": ["./packages/primitives/vegetation/index.ts"],
      "@forge-kit/vegetation/core": ["./packages/primitives/vegetation/core/index.ts"],
      "@forge-kit/vegetation/react": ["./packages/primitives/vegetation/react/index.ts"],
      "@forge-kit/vegetation/*": ["./packages/primitives/vegetation/*"],
      "@forge-kit/map-interface": ["./packages/interfaces/map/index.ts"],
      "@forge-kit/map-interface/*": ["./packages/interfaces/map/*"],
      "@forge-kit/interior-interface": ["./packages/interfaces/interior/index.ts"],
      "@forge-kit/interior-interface/*": ["./packages/interfaces/interior/*"]
    }
  }
}
