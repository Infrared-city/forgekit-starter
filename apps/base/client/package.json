{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "vite build",
    "build:analyze": "vite build && echo 'Bundle analysis: dist/stats.html'",
    "lint": "biome lint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deploy": "bun run build && wrangler pages deploy dist --project-name=my-climate-app",
    "deploy:preview": "bun run build && wrangler pages deploy dist --project-name=my-climate-app --branch=preview"
  },
