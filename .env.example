# ═══════════════════════════════════════════════════════════════════════════
#  REQUIRED — client (Vite) will not render a usable map without these.
#  Copy this file to .env and fill in real values, or export them in your shell.
# ═══════════════════════════════════════════════════════════════════════════

# Mapbox access token — map tiles + geocoder. Get one free at mapbox.com.
VITE_MAPBOX_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════
#  OPTIONAL — feature-gated. Unset = feature off / falls back.
# ═══════════════════════════════════════════════════════════════════════════

# Base URL of your deployed apps/base/api Worker (only needed in production
# builds — local dev proxies /api to http://127.0.0.1:8787, see vite.config.ts).
VITE_API_URL=

# Google Sign-In button on the login page. Without it the button errors.
VITE_GOOGLE_CLIENT_ID=

# ═══════════════════════════════════════════════════════════════════════════
#  Worker secrets (apps/base/api) — NOT read from this file. See
#  apps/base/api/.dev.vars.example for local dev, or `wrangler secret put`
#  for deployed environments.
# ═══════════════════════════════════════════════════════════════════════════
